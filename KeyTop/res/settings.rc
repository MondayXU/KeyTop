#include <windows.h>

101 DIALOGEX 0, 0, 300, 200
STYLE DS_SETFONT | DS_MODALFRAME | DS_FIXEDSYS | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "KeyTop Settings"
FONT 8, "MS Shell Dlg"
BEGIN
    LTEXT "KeyTop Settings", -1, 10, 10, 100, 10
    PUSHBUTTON "Add Mapping", 3001, 10, 30, 50, 14
    DEFPUSHBUTTON "OK", IDOK, 190, 180, 50, 14
    PUSHBUTTON "Cancel", IDCANCEL, 245, 180, 50, 14
END